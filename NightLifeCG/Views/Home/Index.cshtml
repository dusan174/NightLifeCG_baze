@{
    ViewData["Title"] = "NightLifeCG";
}

<div class="container mt-5 text-center">
    <h1 class="display-3 mb-3">🌙 NightLife CG</h1>
    <p class="lead mb-4">Otkrij najbolje klubove i noćni život Crne Gore</p>
    <a asp-controller="Klub" asp-action="Index" class="btn btn-primary btn-lg">
        Istraži klubove →
    </a>
</div>

<div class="container mt-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card p-4">
                <h3>🏙️ @ViewBag.BrojGradova gradova</h3>
                <p class="text-muted">Budva, Podgorica, Bar, Kotor, Tivat</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card p-4">
                <h3>🎵 @ViewBag.BrojKlubova klubova</h3>
                <p class="text-muted">Od beach barova do VIP night clubova</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card p-4">
                <h3>🪑 Rezervacije</h3>
                <p class="text-muted">Rezerviši sto online u par klikova</p>
            </div>
        </div>
    </div>
</div>