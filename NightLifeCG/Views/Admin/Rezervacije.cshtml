@model IEnumerable<NightLifeCG.Models.Rezervacije>

@{
    ViewData["Title"] = "Admin - Rezervacije";
}

<div class="container mt-4">
    <h2 class="mb-4">⚙️ Admin — Sve rezervacije</h2>

    @if (TempData["Uspjeh"] != null)
    {
        <div class="alert alert-success">@TempData["Uspjeh"]</div>
    }
    @if (TempData["Greska"] != null)
    {
        <div class="alert alert-danger">@TempData["Greska"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Korisnik</th>
                <th>Klub</th>
                <th>Sto</th>
                <th>Datum</th>
                <th>Gosti</th>
                <th>Status</th>
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.RezervacijaId</td>
                    <td>@r.Korisnik?.KorisnickoIme</td>
                    <td>@r.Stol?.Klub?.Naziv</td>
                    <td>@r.Stol?.BrojStola</td>
                    <td>@r.DatumRezervacije.ToString("dd.MM.yyyy")</td>
                    <td>@r.BrojGostiju</td>
                    <td>
                        @if (r.Status == 0)
                        {
                            <span class="badge bg-warning text-dark">Na čekanju</span>
                        }
                        else if (r.Status == 1)
                        {
                            <span class="badge bg-success">Potvrđeno</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Otkazano</span>
                        }
                    </td>
                    <td>
                        @if (r.Status == 0)
                        {
                            <a asp-action="Potvrdi" asp-route-id="@r.RezervacijaId"
                               class="btn btn-sm btn-success">✓ Potvrdi</a>
                            <a asp-action="Odbij" asp-route-id="@r.RezervacijaId"
                               class="btn btn-sm btn-danger">✗ Odbij</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Klubovi" class="btn btn-primary mt-2">Upravljaj klubovima</a>
</div>